# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/timesheets

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# Invenias OAuth credentials
INVENIAS_CLIENT_ID=
INVENIAS_CLIENT_SECRET=
INVENIAS_USERNAME=
INVENIAS_PASSWORD=

# Email — sent via Microsoft Graph (uses SharePoint app credentials below)
# Requires Mail.Send application permission granted in Azure AD
SMTP_FROM=matas@peoplelink.lt

# Ask PL — RAG assistant
# OPENAI_API_KEY is required (used for text-embedding-3-small embeddings)
# ANTHROPIC_API_KEY is optional: if set, Claude Haiku is used for chat responses instead of GPT-4o-mini
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# SharePoint integration (Azure AD app with Sites.ReadWrite.All application permission)
# Run GET /documents/api/discover-drives after setup to verify drive name mappings
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_HOSTNAME=peoplelinklt.sharepoint.com
SHAREPOINT_SITE_PATH=sites/main/doc

# Optional overrides (defaults are auto-derived from the category definitions)
# SHAREPOINT_INDEX_DRIVES=Aktualūs dokumentai,Komunikacija,...  # comma-separated; leave blank to auto-index all 43 category drives
# SHAREPOINT_DRIVE_NAME=                                         # default drive for upload/browse when no drive param
# SHAREPOINT_DOCUMENTS_FOLDER=Documents                          # default folder for upload
