# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/timesheets

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# Invenias OAuth credentials (same as invoice-automation .env)
INVENIAS_CLIENT_ID=
INVENIAS_CLIENT_SECRET=
INVENIAS_USERNAME=
INVENIAS_PASSWORD=

# SharePoint backup (Azure AD app with Sites.ReadWrite.All permission)
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_HOSTNAME=peoplelink.sharepoint.com
SHAREPOINT_SITE_PATH=sites/IT
SHAREPOINT_BACKUP_FOLDER=Timesheets/Backups
